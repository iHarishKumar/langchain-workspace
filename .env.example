# --- Credentials ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# --- Model config (read by every notebook) ---
# Switch providers/models here without editing any notebook code.
# The matching integration package must be installed (e.g. langchain-openai).

# Chat model in "provider:model" form — init_chat_model reads the provider from the prefix.
CHAT_MODEL=openai:gpt-4o-mini

# Embeddings: model name + provider (init_embeddings takes them separately).
MODEL_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Optional: LangSmith tracing & evaluation (lesson 12) ---
# Key from https://smith.langchain.com → Settings → API Keys. Free tier available.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY
# LANGSMITH_PROJECT=langchain-workspace
